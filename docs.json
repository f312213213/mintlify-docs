              "guides/account-billing",
              "guides/faq"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open JobBeacon",
          "href": "https://jobbeacon.app/dashboard",
          "icon": "arrow-up-right-from-square"
