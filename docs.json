          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Watching companies",
            "pages": [
              "guides/adding-companies",
              "guides/supported-platforms",
              "guides/filters"
            ]
          },
          {
            "group": "Staying notified",
            "pages": [
              "guides/notifications",
              "guides/sharing"
            ]
          },
          {
            "group": "Account",
